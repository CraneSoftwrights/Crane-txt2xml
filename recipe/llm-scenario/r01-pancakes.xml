<?xml version="1.0" encoding="UTF-8"?>
<Recipe>
  <Title>Pancakes</Title>
  <Ingredient>
    <Name>Flour</Name>
    <Amount unit="cups">2</Amount>
  </Ingredient>
  <Ingredient>
    <Name>Milk</Name>
    <Amount unit="cups">1.5</Amount>
  </Ingredient>
  <Ingredient>
    <Name>Egg</Name>
    <Amount unit="whole">2</Amount>
  </Ingredient>
  <Step>Whisk the dry ingredients together</Step>
  <Step>Add milk and eggs and mix until smooth</Step>
  <Step>Cook on a greased griddle until golden</Step>
  <Step>Serve warm with syrup</Step>
</Recipe>
